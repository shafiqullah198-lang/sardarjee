# Django API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Request timeout in milliseconds
VITE_API_TIMEOUT_MS=15000

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Django email / password reset
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_smtp_user
EMAIL_HOST_PASSWORD=your_smtp_password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=Sardar-G Fabrics <no-reply@sardargfabric.com>
FRONTEND_URL=http://localhost:5173
