# Django API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Request timeout in milliseconds
VITE_API_TIMEOUT_MS=15000

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Django email / password reset
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=your_smtp_user
DJANGO_EMAIL_HOST_PASSWORD=your_smtp_password
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false
DJANGO_DEFAULT_FROM_EMAIL=Sardar-G Fabrics <no-reply@sardargfabric.com>
